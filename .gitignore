# Broad demo whitelists above must not re-include machine history, credentials, or generated caches.
demos/**/.DS_Store
demos/**/.Rhistory
demos/**/__pycache__/
demos/**/*.py[cod]
demos/**/.env
demos/**/.env.*
!demos/**/.env.example


{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "reported DE table (canonical long form)",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["feature_id"],
    "properties": {
      "feature_id": { "type": "string" },
      "pvalue": { "type": ["number", "null"] },
      "padj": { "type": ["number", "null"] },
      "effect": { "type": ["number", "null"] },
      "unit_of_test": { "type": ["string", "null"], "enum": ["cell", "sample", null] }
    }
  }
}

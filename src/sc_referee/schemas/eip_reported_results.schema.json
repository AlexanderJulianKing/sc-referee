{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EIP reported results (stat_tests/<Gene>_*.csv)",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["exon"],
    "properties": {
      "exon": {},
      "p_value": { "type": ["number", "null"] },
      "delta_incl": { "type": ["number", "null"] },

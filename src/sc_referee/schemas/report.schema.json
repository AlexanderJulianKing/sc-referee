{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "sc-referee report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "analysis_type", "confirmed_by_human", "worst_status", "ci_fails", "ci_conclusion", "fully_audited",
    "analyses", "coverage", "findings"
  ],
  "properties": {
    "analysis_type": { "type": ["string", "null"] },
    "confirmed_by_human": { "type": "boolean" },
    "worst_status": { "$ref": "#/definitions/status" },
    "ci_fails": { "type": "boolean" },
    "ci_conclusion": { "enum": ["fail", "pass"] },
    "fully_audited": { "type": "boolean" },
    "analyses": {
      "type": "array", "minItems": 1,
      "items": { "$ref": "#/definitions/analysis" }
    },
    "coverage": { "$ref": "#/definitions/coverage" },
    "findings": {
      "type": "array", "minItems": 1,
      "items": { "$ref": "#/definitions/finding" }
    },
    "diagnostics": {
      "type": "array",
      "items": { "type": "object" }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "ci_conclusion": { "const": "fail" } } },
      "then": {
        "properties": {
          "ci_fails": { "const": true },
          "worst_status": { "$ref": "#/definitions/status" }
        }
      }
    },
    {
      "if": { "properties": { "ci_fails": { "const": true } } },
      "then": {
        "properties": {
          "ci_conclusion": { "const": "fail" }
        }
      },
      "else": { "properties": { "ci_conclusion": { "const": "pass" } } }
    },
    {
      "if": { "properties": { "ci_conclusion": { "const": "pass" } } },
      "then": {
        "properties": {
          "ci_fails": { "const": false },
          "worst_status": { "enum": ["informational", "pass"] }
        }
      }
    }
  ],
  "definitions": {
    "status": {
      "enum": ["blocker", "major", "needs_evidence", "informational", "not_audited", "pass"]
    },
    "coverage": {
      "type": "object", "additionalProperties": false,
      "required": ["findings", "human_states", "statuses"],
      "properties": {
        "findings": { "type": "integer", "minimum": 0 },
        "human_states": {
          "type": "object", "additionalProperties": false,
          "properties": {
            "clear": { "type": "integer", "minimum": 1 },
            "flagged": { "type": "integer", "minimum": 1 },
            "not_checked": { "type": "integer", "minimum": 1 },
            "n_a": { "type": "integer", "minimum": 1 }
          }
        },
        "statuses": {
          "type": "object", "additionalProperties": false,
          "properties": {
            "blocker": { "type": "integer", "minimum": 1 },
            "major": { "type": "integer", "minimum": 1 },
            "needs_evidence": { "type": "integer", "minimum": 1 },
            "informational": { "type": "integer", "minimum": 1 },
            "not_audited": { "type": "integer", "minimum": 1 },
            "pass": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "conditional_on": {
      "type": "object", "additionalProperties": false,
      "required": [
        "contract_id", "contract_type", "decisive_fields", "plain_language_premise", "scope"
      ],
      "properties": {
        "contract_id": { "type": "string" },
        "contract_type": { "type": "string" },
        "decisive_fields": { "type": "object" },
        "plain_language_premise": { "type": "string" },
        "scope": { "type": "object" },
        "component_identities": { "type": "object" }
      }
    },
    "finding": {
      "type": "object", "additionalProperties": false,
      "required": [
        "check_id", "status", "human_state", "applicability", "judgment", "coverage",
        "proof_grade", "verdict", "metrics", "citations", "fix"
      ],
      "properties": {
        "check_id": { "type": "string", "minLength": 1 },
        "status": { "$ref": "#/definitions/status" },
        "human_state": { "enum": ["clear", "flagged", "not_checked", "n_a"] },
        "applicability": { "enum": ["applies", "not_applicable", "unknown"] },
        "judgment": { "type": ["string", "null"], "enum": ["conformant", "violation", "concern", "unresolved", null] },
        "coverage": { "enum": ["complete", "partial", "not_run"] },
        "proof_grade": { "type": ["string", "null"], "enum": ["exact", "recomputed", "structural", "advisory", null] },
        "verdict": { "type": "string" },
        "metrics": { "type": "object" },
        "citations": { "type": "array", "items": { "type": "string" } },
        "fix": { "type": ["string", "null"] },
        "conditional_on": { "$ref": "#/definitions/conditional_on" }
      }
    },
    "analysis": {
      "type": "object", "additionalProperties": false,
      "required": ["claim", "recognition", "findings", "coverage"],
      "properties": {
        "claim": { "type": ["object", "null"] },
        "recognition": { "type": "string" },
        "findings": {
          "type": "array", "minItems": 1,
          "items": { "$ref": "#/definitions/finding" }
        },
        "coverage": { "$ref": "#/definitions/coverage" }
      }
    }
  }
}
